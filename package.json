{
  "name": "wizard-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:client-ui": "ng build client-ui",
    "dev": "pnpm --parallel --filter @wizard/server --filter @wizard/client-ui dev",
    "dev:client-ui": "ng serve client-ui --port 4200",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "@types/pg": "8.11.11"
    }
  }
}
